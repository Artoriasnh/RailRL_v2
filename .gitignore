.DS_Store

# Data — raw inputs are LARGE; tracked separately, not in git
data/raw/TD_data.csv
data/raw/Movements.csv

# Outputs — generated artefacts, regenerable from scripts
# Keep outputs/ structure for downstream code, but don't commit big binaries
outputs/**/*.parquet
outputs/**/*.png
# model checkpoints (24-48MB each, regenerable from training)
outputs/**/*.pt
# publication raster figures (40-55MB; commit the small svg/pdf instead)
outputs/**/*.tiff
outputs/**/*.npy
outputs/**/*.npz
outputs/cache/

# But DO commit small JSON summaries and markdown reports
!outputs/**/*.json
!outputs/**/*.md

# Legacy v1 archive — read-only reference
outputs/_legacy_v1_binary/**/*.parquet
outputs/_legacy_v1_binary/**/*.pt
outputs/_legacy_v1_binary/**/*.npz

# Generated docs
docs/_build/

# OS
Thumbs.db
*.lnk
